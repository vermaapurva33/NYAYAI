# backend/.env.example
# Copy to .env and fill in your values
#   cp .env.example .env

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:    http://localhost:8501
# Docker:       http://frontend:8501
# Production:   https://your-streamlit-domain.com
ALLOWED_ORIGINS=http://localhost:8501

# ── Model ─────────────────────────────────────────────────────────────────────
# Absolute or relative path to the trained model directory.
# Relative paths are resolved from the backend/ folder.
MODEL_PATH=../models/nyayai-error-detector

# ── GPU ───────────────────────────────────────────────────────────────────────
USE_GPU=true

# ── Database (for future Phase 2 vector store) ────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Firebase Authentication ───────────────────────────────────────────────────
# Path to the downloaded Service Account JSON file (keep this out of version control!)
FIREBASE_CREDENTIALS=firebase_service_account.json
