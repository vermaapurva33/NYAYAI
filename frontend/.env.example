# ── Backend connection ────────────────────────────────────────────────────────
# URL of the NyayAI backend API server.
# Local dev:   http://localhost:8000
# Docker:      http://backend:8000   (uses Docker internal DNS)
# Production:  https://api.your-domain.com
BACKEND_URL=http://localhost:8000

